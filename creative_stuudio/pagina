<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Creative Stuudio</title>
    <link rel="stylesheet" href="style.css" />
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;800&display=swap" rel="stylesheet">

<style>
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: 'Poppins', sans-serif;
}

/* NAV */
.navbar {
    width: 100%;
    position: fixed;
    top: 0;
    padding: 20px 50px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: rgba(10, 10, 20, 0.7);
    backdrop-filter: blur(10px);
    z-index: 100;
}

.logo {
    font-size: 26px;
    font-weight: 800;
    color: #fff;
}

.logo span {
    color: #7b4bff;
}

.menu a {
    color: #ddd;
    text-decoration: none;
    margin-left: 30px;
    font-size: 16px;
    transition: .3s;
}

.menu a:hover {
    color: #8b5dff;
}

/* HERO */
.hero {
    height: 100vh;
    background: url('hero-bg.jpg') center/cover no-repeat;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 100px 20px;
}

.hero h1 {
    color: #fff;
    font-size: 60px;
    font-weight: 800;
    text-shadow: 0 0 15px #8b5dff;
}

.hero p {
    color: #ccc;
    margin: 20px 0;
    font-size: 18px;
}

.hero-buttons .btn-primary,
.hero-buttons .btn-secondary {
    padding: 12px 30px;
    margin: 10px;
    border-radius: 50px;
    font-size: 18px;
    cursor: pointer;
    text-decoration: none;
}

.btn-primary {
    background: #7b4bff;
    color: #fff;
}

.btn-secondary {
    border: 2px solid #7b4bff;
    color: #7b4bff;
}

/* SERVICES */
.services {
    padding: 100px 50px;
    background: #0e0b20;
    text-align: center;
}

.services h2 {
    color: #fff;
    font-size: 40px;
    margin-bottom: 50px;
}

.service-grid {
    display: flex;
    justify-content: center;
    gap: 40px;
}

.service-card {
    background: #1a1535;
    padding: 30px;
    width: 300px;
    border-radius: 20px;
    box-shadow: 0 0 20px rgba(123, 75, 255, 0.2);
    color: #ddd;
}

/* PROJECTS */
.projects {
    padding: 100px 50px;
    background: #0c0a1a;
    text-align: center;
}

.projects h2 {
    color: #fff;
    font-size: 40px;
    margin-bottom: 50px;
}

.project-grid {
    display: flex;
    justify-content: center;
    gap: 40px;
}

.project-card {
    width: 300px;
    background: #1a1535;
    border-radius: 20px;
    overflow: hidden;
    color: #ccc;
    padding-bottom: 20px;
}

.project-card img {
    width: 100%;
    height: 200px;
    object-fit: cover;
}

/* CONTACT */
.contact {
    padding: 100px 50px;
    background: #110d22;
    text-align: center;
}

.contact h2 {
    color: #fff;
    font-size: 40px;
    margin-bottom: 40px;
}

.contact-form {
    max-width: 500px;
    margin: auto;
    display: flex;
    flex-direction: column;
    gap: 15px;
}

.contact-form input,
.contact-form textarea {
    padding: 14px;
    border: none;
    border-radius: 10px;
    background: #1a1535;
    color: #fff;
}

.contact-form button {
    background: #7b4bff;
    color: #fff;
    padding: 15px;
    border-radius: 50px;
    font-size: 18px;
    cursor: pointer;
}

/* FOOTER */
.footer {
    background: #0a0715;
    color: #888;
    text-align: center;
    padding: 20px;
}
</style>
</head>
<body>

    <!-- NAV -->
    <header class="navbar">
        <div class="logo">Creative <span>Stuudio</span></div>
        <nav class="menu">
            <a href="#home">Home</a>
            <a href="#services">Servicios</a>
            <a href="#projects">Proyectos</a>
            <a href="#contact">Contacto</a>
        </nav>
    </header>

    <!-- HERO -->
    <section id="home" class="hero">
        <div class="hero-content">
            <h1>Diseñamos Experiencias Digitales</h1>
            <p>Soluciones creativas en diseño, desarrollo y branding, con un estilo futurista y moderno.</p>
            <div class="hero-buttons">
                <a class="btn-primary" href="#contact">Comenzar</a>
                <a class="btn-secondary" href="#projects">Ver Proyectos</a>
            </div>
        </div>
    </section>

    <!-- SERVICES -->
    <section id="services" class="services">
        <h2>Nuestros Servicios</h2>
        <div class="service-grid">
            <div class="service-card">
                <h3>Diseño Web</h3>
                <p>Landing pages, sitios modernos, UI/UX y optimización visual.</p>
            </div>
            <div class="service-card">
                <h3>Desarrollo</h3>
                <p>Integraciones, HTML, CSS, JS, PHP y soluciones personalizadas.</p>
            </div>
            <div class="service-card">
                <h3>Branding & Identidad</h3>
                <p>Logotipos, paletas de color, estilo visual y guía de marca.</p>
            </div>
        </div>
    </section>

    <!-- PROJECTS -->
    <section id="projects" class="projects">
        <h2>Proyectos Destacados</h2>
        <div class="project-grid">
            <div class="project-card">
                <img src="project1.jpg" alt="Proyecto 1" />
                <h3>Landing Restaurantes</h3>
                <p>Sitio moderno con reservas online y menú dinámico.</p>
            </div>

            <div class="project-card">
                <img src="project2.jpg" alt="Proyecto 2" />
                <h3>Creative Agency</h3>
                <p>Diseño limpio, animaciones suaves y branding completo.</p>
            </div>

            <div class="project-card">
                <img src="project3.jpg" alt="Proyecto 3" />
                <h3>Portfolio Personal</h3>
                <p>Estilo minimalista, elegante y totalmente responsive.</p>
            </div>
        </div>
    </section>

    <!-- CONTACT -->
    <section id="contact" class="contact">
        <h2>Contacto</h2>
        <form class="contact-form">
            <input type="text" placeholder="Nombre" required>
            <input type="email" placeholder="Email" required>
            <textarea placeholder="Mensaje" required></textarea>
            <button class="btn-primary" type="submit">Enviar</button>
        </form>
    </section>

    <!-- FOOTER -->
    <footer class="footer">
        <p>© 2025 Creative Stuudio — Todos los derechos reservados</p>
    </footer>

    <script src="script.js"></script>
</body>
</html>
